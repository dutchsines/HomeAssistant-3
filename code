                as_timestamp(state_attr('sun.sun','next_setting'), 0) %}

                {% set elev = states('sensor.sun_solar_elevation') | float(-90)
                %}


                {% if sun_state == 'above_horizon' %}
                  {% set rise_ts = next_rise %}
                  {% if next_rise > now_ts %}{% set rise_ts = next_rise - 86400 %}{% endif %}
                  {% set set_ts = next_set %}
                  {% set denom = (set_ts - rise_ts) if (set_ts - rise_ts) > 0 else 1 %}
                  {% set progress = (now_ts - rise_ts) / denom %}
                  {% set progress = 0 if progress < 0 else (1 if progress > 1 else progress) %}
                  {% set sun_x = (10 + (80 * progress)) %}
                  {% set e = elev if elev > 0 else 0 %}
                  {% set e = 70 if e > 70 else e %}
                  {% set sun_y = (85 - (80 * (e / 70))) %}
