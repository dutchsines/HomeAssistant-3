views:
  - title: Tempest
    sections:
      - type: grid
        cards:
          - type: custom:stack-in-card
            mode: vertical
            keep:
              margin: false
            card_mod:
              style: |
                ha-card {
                  position: relative;
                  background: transparent !important;
                  box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5) !important;
                  border-radius: 20px !important;
                  overflow: hidden;
                }
            cards:
              - type: custom:better-moment-card
                parentStyle: |
                  line-height: 1;
                  padding: 5px !important;
                moment:
                  - parentStyle: >
                      font-size: 2.2em; text-align: center; font-weight: 500;
                      margin: 0;
                    templateRaw: |
                      {{moment format=hh:mm:ss}}
                  - parentStyle: >
                      font-size: 1.1em; text-align: center; margin: 2px 0;
                      opacity: 0.8;
                    templateRaw: |
                      {{moment format=cccc, LLL dd, yyyy}}
                card_mod:
                  style: >
                    :host { --bubble-border-radius: 20px !important; }

                    /* ----------------------------
                       WIND DIRECTION (degrees) -> glow position
                       ---------------------------- */
                    {% set deg = states('sensor.st_00176926_wind_direction') |
                    float(0) %} {% set rad = (deg - 90) * 3.14159265 / 180 %} {%
                    set wind_x = 50 + (45 * (rad | cos)) %} {% set wind_y = 50 +
                    (45 * (rad | sin)) %}

                    /* NORTH = RED | SOUTH = BLUE (smooth cosine) */ {% set
                    north_strength = ((deg * 3.14159265 / 180) | cos + 1) / 2 %}
                    {% set red  = (255 * north_strength) | int %} {% set blue =
                    (255 * (1 - north_strength)) | int %} {% set wind_rgba =
                    'rgba(' ~ red ~ ', 40, ' ~ blue ~ ', 0.55)' %}

                    /* ----------------------------
                       LUX -> TOP COLOR (sun glow color)
                       ---------------------------- */
                    {% set lux = states('sensor.st_00176926_illuminance') |
                    float(0) %} {% set top_color = '#05060A' %} {% if lux >=
                    100000 %}
                      {% set top_color = '#FFFFFF' %}
                    {% elif lux >= 60000 %}
                      {% set top_color = '#FFF2CC' %}
                    {% elif lux >= 40000 %}
                      {% set top_color = '#FFB36A' %}
                    {% elif lux >= 20000 %}
                      {% set top_color = '#FFD59A' %}
                    {% elif lux >= 10000 %}
                      {% set top_color = '#E9F6FF' %}
                    {% elif lux >= 5000 %}
                      {% set top_color = '#7EC8FF' %}
                    {% elif lux >= 2500 %}
                      {% set top_color = '#9FD6C8' %}
                    {% elif lux >= 1000 %}
                      {% set top_color = '#B8D9F2' %}
                    {% elif lux >= 400 %}
                      {% set top_color = '#78AEDD' %}
                    {% elif lux >= 150 %}
                      {% set top_color = '#4C7FB8' %}
                    {% elif lux >= 60 %}
                      {% set top_color = '#2A4C7A' %}
                    {% elif lux >= 20 %}
                      {% set top_color = '#1A2E5A' %}
                    {% elif lux >= 5 %}
                      {% set top_color = '#121A3A' %}
                    {% elif lux >= 1 %}
                      {% set top_color = '#0A1026' %}
                    {% endif %}

                    /* ----------------------------
                       TEMP -> BOTTOM COLOR
                       ---------------------------- */
                    {% set temp = states('sensor.st_00176926_air_temperature') |
                    float(0) %} {% set bottom_color = '#D8C8B8' %} {% if temp >=
                    105 %}
                      {% set bottom_color = '#58141D' %}
                    {% elif temp >= 100 %}
                      {% set bottom_color = '#B32821' %}
                    {% elif temp >= 95 %}
                      {% set bottom_color = '#C73E1D' %}
                    {% elif temp >= 90 %}
                      {% set bottom_color = '#E35D27' %}
                    {% elif temp >= 85 %}
                      {% set bottom_color = '#FF7518' %}
                    {% elif temp >= 80 %}
                      {% set bottom_color = '#FF9C00' %}
                    {% elif temp >= 75 %}
                      {% set bottom_color = '#FFD200' %}
                    {% elif temp >= 70 %}
                      {% set bottom_color = '#FFEC00' %}
                    {% elif temp >= 65 %}
                      {% set bottom_color = '#A9C94C' %}
                    {% elif temp >= 60 %}
                      {% set bottom_color = '#7DBB48' %}
                    {% elif temp >= 55 %}
                      {% set bottom_color = '#6DB04A' %}
                    {% elif temp >= 50 %}
                      {% set bottom_color = '#4C9F38' %}
                    {% elif temp >= 45 %}
                      {% set bottom_color = '#1D9D73' %}
                    {% elif temp >= 40 %}
                      {% set bottom_color = '#00A19A' %}
                    {% elif temp >= 35 %}
                      {% set bottom_color = '#6CC6CE' %}
                    {% elif temp >= 30 %}
                      {% set bottom_color = '#9ED4F0' %}
                    {% elif temp >= 25 %}
                      {% set bottom_color = '#2C5AA0' %}
                    {% elif temp >= 20 %}
                      {% set bottom_color = '#1C3D7A' %}
                    {% elif temp >= 15 %}
                      {% set bottom_color = '#5C4699' %}
                    {% elif temp >= 10 %}
                      {% set bottom_color = '#7E58A0' %}
                    {% elif temp >= 5 %}
                      {% set bottom_color = '#856A67' %}
                    {% elif temp >= 0 %}
                      {% set bottom_color = '#A6A1A1' %}
                    {% elif temp >= -5 %}
                      {% set bottom_color = '#BFB6AF' %}
                    {% endif %}

                    /* -----------------------------
                       SUN POSITION (X + Y)
                       ----------------------------- */
                    {% set is_night = is_state('sun.sun','below_horizon') %} {%
                    set has_sun = not is_night %}

                    {% set sun_state = states('sun.sun') %} {% set now_ts =
                    as_timestamp(now()) %} {% set next_rise =
                    as_timestamp(state_attr('sun.sun','next_rising'), 0) %} {%
                    set next_set  =
                    as_timestamp(state_attr('sun.sun','next_setting'), 0) %} {%
                    set elev = states('sensor.sun_solar_elevation') | float(-90)
                    %}

                    {% if sun_state == 'above_horizon' %}
                      {% set rise_ts = next_rise %}
                      {% if next_rise > now_ts %}{% set rise_ts = next_rise - 86400 %}{% endif %}
                      {% set set_ts = next_set %}
                      {% set denom = (set_ts - rise_ts) if (set_ts - rise_ts) > 0 else 1 %}
                      {% set progress = (now_ts - rise_ts) / denom %}
                      {% set progress = 0 if progress < 0 else (1 if progress > 1 else progress) %}
                      {% set sun_x = (10 + (80 * progress)) %}

                      {% set e = elev %}
                      {% set e = 0 if e < 0 else e %}
                      {% set e = 70 if e > 70 else e %}
                      {% set sun_y = (85 - (80 * (e / 70))) %}
                      {% set sun_opacity = 0.95 %}
                    {% else %}
                      {% set sun_x = 50 %}
                      {% set sun_y = 120 %}
                      {% set sun_opacity = 0.35 %}
                    {% endif %}

                    /* ----------------------------
                       CARD BASE
                       ---------------------------- */
                    ha-card {
                      position: relative;
                      background: transparent !important;
                      box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5) !important;
                      overflow: hidden;
                      transform-origin: top;
                      /* make it look attached */
                      border-top-left-radius: 16px !important;
                      border-top-right-radius: 16px !important;
                      border-bottom-left-radius: 0px !important;
                      border-bottom-right-radius: 0px !important;
                    } /* ONE unified glow layer */ ha-card::before {
                      content: "";
                      position: absolute;
                      inset: -25%;
                      pointer-events: none;
                      z-index: 0;

                      {# make sun layers “always valid” #}
                      {% set sun_outer = (top_color ~ '33') if has_sun else 'rgba(0,0,0,0)' %}
                      {% set sun_mid   = (top_color ~ '66') if has_sun else 'rgba(0,0,0,0)' %}
                      {% set sun_core  = (top_color ~ 'CC') if has_sun else 'rgba(0,0,0,0)' %}

                      background:
                        /* 🌞 OUTER ATMOSPHERIC GLOW (big + soft) */
                        radial-gradient(
                          circle at {{ sun_x }}% {{ sun_y }}%,
                          {{ sun_outer }} 0%,
                          rgba(0,0,0,0) 50%
                        ),

                        /* ☀️ MID AURA (adds body) */
                        radial-gradient(
                          circle at {{ sun_x }}% {{ sun_y }}%,
                          {{ sun_mid }} 0%,
                          rgba(0,0,0,0) 25%
                        ),

                        /* 🔆 INNER HALO (brighter) */
                        radial-gradient(
                          circle at {{ sun_x }}% {{ sun_y }}%,
                          {{ sun_core }} 10%,
                          rgba(0,0,0,0) 0%
                        ),

                        /* 🌡️ TEMP GLOW (BOTTOM) — this was upside-down in your version */
                        radial-gradient(
                          circle at 50% 0%,
                          {{ bottom_color ~ '88' }} 50%,
                          rgba(0,0,0,0) 100%
                        );

                      opacity: 1;
                      filter: blur(18px);
                    }


                    /* Keep content above glows + ring */ ha-card > * {
                      position: relative;
                      z-index: 2;
                    }
              - type: markdown
                content: |
                  {{ states('input_text.hourly_ai_joke') }}
                text_only: true
                card_mod:
                  style: |
                    ha-card {
                      background: rgba(0,0,0,0.25) !important;
                      backdrop-filter: blur(8px);
                      -webkit-backdrop-filter: blur(8px);
                      padding: 5px 8px !important;
                      z-index: -1;
                      font-size: 1.15em;

                      /* make it look attached */
                      border-top-left-radius: 0px !important;
                      border-top-right-radius: 0px !important;
                      border-bottom-left-radius: 16px !important;
                      border-bottom-right-radius: 16px !important;

                      /* remove the seam gap */
                      margin-top: -10px !important;
                      box-shadow: 0 0 10px rgba(0,0,0,0.35) !important;
                    }
                    ha-card .content {
                      text-align: center;
                      white-space: normal !important;
                      overflow-wrap: anywhere !important;
                      word-break: break-word !important;
                      line-height: 1.35;
                      font-size: 1.15em;
                    }
          - type: horizontal-stack
            cards:
              - type: vertical-stack
                cards:
                  - type: custom:bubble-card
                    card_type: button
                    button_type: state
                    show_state: true
                    show_last_changed: false
                    show_last_updated: false
                    grid_options:
                      columns: 4
                      rows: 1
                    name: Dutch Moto
                    icon: ''
                    show_attribute: false
                    force_icon: false
                    card_layout: normal
                    show_icon: false
                    scrolling_effect: false
                    entity: device_tracker.dutch_moto
                    sub_button:
                      main: []
                      bottom: []
                    card_mod:
                      style: >
                        :host { --bubble-border-radius: 16px !important; }

                        /* Transparent card background */ ha-card, .bubble-card,
                        .card-content, #card {
                          background: transparent !important;
                          box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5) !important;
                          border-radius: 16px !important;
                        }

                        /* ====== JINJA VARS ====== */ {% set location_state =
                        states('device_tracker.dutch_moto') %} {% set name_color
                        = '#607D8B' %} {% set name_text  = 'Dutch' %} {% set
                        loc_gif    = '/local/emoji_gifs/pin.gif' %}

                        {% if location_state == 'home' %}
                          {% set loc_gif = '/local/emoji_gifs/home.gif' %}
                          {% set name_color = '#4CAF50' %}
                          {% set name_text = 'Dutch' %}
                        {% elif location_state == 'pizza' %}
                          {% set loc_gif = '/local/emoji_gifs/pizza.gif' %}
                          {% set name_color = '#FFC107' %}
                          {% set name_text = 'Pizza Hut' %}
                        {% elif location_state in ['stjoe', 'kc'] %}
                          {% set loc_gif = '/local/emoji_gifs/city.gif' %}
                          {% set name_color = '#89CFF0' %}
                          {% set name_text = 'City' %}
                        {% elif location_state == 'hospital' %}
                          {% set loc_gif = '/local/emoji_gifs/hospital.gif' %}
                          {% set name_color = '#1EE588' %}
                          {% set name_text = 'Hospital' %}
                        {% elif 'grandparents' in location_state %}
                          {% set loc_gif = '/local/emoji_gifs/grandma.gif' %}
                          {% set name_color = '#9C27B0' %}
                          {% set name_text = 'Grandparents' %}
                        {% elif location_state == 'dad and debs' %}
                          {% set loc_gif = '/local/emoji_gifs/family.gif' %}
                          {% set name_color = '#F4511E' %}
                          {% set name_text = 'Dad & Debs' %}
                        {% elif location_state == 'wal' %}
                          {% set loc_gif = '/local/emoji_gifs/cart.gif' %}
                          {% set name_color = '#1E88E5' %}
                          {% set name_text = 'Walmart' %}
                        {% elif location_state == 'auto' %}
                          {% set loc_gif = '/local/emoji_gifs/car.gif' %}
                          {% set name_color = '#1E88E5' %}
                          {% set name_text = 'Autos-4-U' %}
                        {% elif location_state == 'mc' %}
                          {% set loc_gif = '/local/emoji_gifs/burger.gif' %}
                          {% set name_color = '#FFC107' %}
                          {% set name_text = 'McDonalds' %}
                        {% elif location_state == 'not_home' %}
                          {% set loc_gif = '/local/emoji_gifs/racing.gif' %}
                          {% set name_color = '#E53935' %}
                          {% set name_text = 'Driving' %}
                        {% endif %}

                        /* ====== GEO + COLORS ====== */ {% set geo =
                        states('sensor.dutch_moto_geocoded_location') %} {% set
                        geo_text = geo if geo not in
                        ['unknown','unavailable','none',''] else '—' %}

                        /* LEFT SIDE = SAME AS LOCATION COLOR (name_color), but
                        transparent */ {% set left_color = name_color ~ '33'
                        %}   {# ~20% alpha #}

                        /* GEO TEXT COLOR = "random" but stable (based on
                        geocode text) */ {% set hex = (geo_text | md5)[0:6] %}
                        {% set n = hex | int(base=16) %} {% set hue = n % 360 %}
                        {% set geo_text_color = 'hsla(' ~ hue ~ ', 90%, 70%, 1)'
                        %}

                        /* ====== NAME/TOP TITLE ====== */ .bubble-name {
                          visibility: hidden;
                          position: relative;
                        }

                        .bubble-name::before {
                          visibility: visible;
                          position: absolute;
                          left: 0; right: 0;
                          top: 0;
                          text-align: center;
                          font-weight: 600;
                          font-size: 1.4em;
                          text-shadow: 1px 1px 3px rgba(0,0,0,0.9);
                          color: {{ name_color }} !important;
                          content: "{{ name_text }}";

                          padding-left: 34px;
                          padding-right: 34px;
                          background-image: url('{{ loc_gif }}'), url('{{ loc_gif }}');
                          background-repeat: no-repeat, no-repeat;
                          background-size: 24px 24px, 24px 24px;
                          background-position: left center, right center;
                        }

                        /* ====== CORE: hide original state text ====== */
                        .state {
                          position: relative;
                          height: 100%;
                          color: transparent !important;
                        }

                        /* ====== GEO (bottom left) ====== */ .state::before {
                          position: absolute;
                          bottom: -.5em;
                          left: 0em;
                          text-align: left;
                          font-weight: 500;
                          text-shadow: 1px 1px 3px rgba(0,0,0,0.9);

                          max-width: 70%;
                          overflow: hidden;
                          white-space: nowrap;
                          text-overflow: ellipsis;

                          font-size: .9em !important;
                          content: "{{ geo_text }}";
                          color: {{ geo_text_color }} !important;
                          padding-left: 0px;
                          background-repeat: no-repeat;
                          background-size: 16px 16px;
                          background-position: left center;
                        }

                        /* ====== PHONE BATTERY (bottom right) ====== */
                        .state::after {
                          position: absolute;
                          bottom: -.3em;
                          right: .5em;
                          text-align: right;
                          font-weight: 700;
                          text-shadow: 1px 1px 3px rgba(0,0,0,0.9);

                          {% set is_charging   = is_state('sensor.dutch_moto_battery_state', 'charging') %}
                          {% set battery_level = states('sensor.dutch_moto_battery_level') | float(0) | int %}
                          {% set right_color   = '#607D8B33' %}
                          {% set batt_gif      = '/local/emoji_gifs/battery.gif' %}

                          {% if is_charging %}
                            {% set batt_gif = '/local/emoji_gifs/charging.gif' %}
                            {% set right_color = '#4CAF5033' %}
                          {% elif battery_level > 80 %}
                            {% set batt_gif = '/local/emoji_gifs/battery.gif' %}
                            {% set right_color = '#4CAF5033' %}
                          {% elif battery_level > 30 %}
                            {% set batt_gif = '/local/emoji_gifs/orange.gif' %}
                            {% set right_color = '#FFC10733' %}
                          {% else %}
                            {% set batt_gif = '/local/emoji_gifs/batterylow.gif' %}
                            {% set right_color = '#E5393533' %}
                          {% endif %}

                          font-size: 1.2em !important;
                          content: "{{ battery_level }}%";
                          color: {{ 'var(--success-color)' if battery_level > 80 else 'var(--warning-color)' if battery_level > 30 else 'var(--error-color)' }} !important;

                          padding-right: 26px;
                          background-image: url('{{ batt_gif }}');
                          background-repeat: no-repeat;
                          background-size: 18px 18px;
                          background-position: right center;
                        }

                        /* ====== BACKGROUND GRADIENT ====== */ .bubble-button,
                        .bubble-button-inner {
                          {% set mid_color = '#607D8B4D' %}
                          {% if location_state == 'home' %}{% set mid_color = '#4CAF504D' %}
                          {% elif location_state == 'pizza' %}{% set mid_color = '#FFC1074D' %}
                          {% elif location_state == 'hospital' %}{% set mid_color = '#0F52BAAA' %}
                          {% elif location_state in ['stjoe', 'kc'] %}{% set mid_color = '#89CFF0AA' %}
                          {% elif 'grandparents' in location_state %}{% set mid_color = '#9C27B04D' %}
                          {% elif location_state == 'not_home' %}{% set mid_color = '#E539354D' %}
                          {% endif %}

                          background: linear-gradient(
                            to right,
                            {{ left_color }},
                            {{ mid_color }} 30%,
                            {{ mid_color }} 70%,
                            {{ right_color }}
                          ) !important;

                          backdrop-filter: blur(6px);
                          -webkit-backdrop-filter: blur(6px);
                          border: none !important;
                        }
                  - type: custom:mini-graph-card
                    name: ' '
                    hours_to_show: 12
                    points_per_hour: 60
                    animate: false
                    smoothing: true
                    show:
                      graph: bar
                      legend: false
                      state: false
                      icon: false
                      extrema: false
                      name: false
                      labels: false
