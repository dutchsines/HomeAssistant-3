                      {% set now_ts = as_timestamp(now()) %}
                      {% set rise_ts = as_timestamp(state_attr('sun.sun','next_rising'), 0) %}
                      {% set set_ts  = as_timestamp(state_attr('sun.sun','next_setting'), 0) %}

                      {# make rise_ts be today's sunrise #}
                      {% if rise_ts > now_ts %}{% set rise_ts = rise_ts - 86400 %}{% endif %}

                      {# ensure set_ts is after rise_ts #}
                      {% if set_ts < rise_ts %}{% set set_ts = set_ts + 86400 %}{% endif %}

                      {# start of local day #}
                      {% set day_start = as_timestamp(now().replace(hour=0, minute=0, second=0, microsecond=0)) %}

                      {# map sunrise/sunset onto 0-100% of day #}
                      {% set sunrise_pct = ((rise_ts - day_start) / 86400 * 100) %}
                      {% set sunset_pct  = ((set_ts  - day_start) / 86400 * 100) %}

                      {# solar noon = midpoint between sunrise and sunset #}
                      {% set noon_ts = rise_ts + ((set_ts - rise_ts) / 2) %}
                      {% set noon_pct = ((noon_ts - day_start) / 86400 * 100) %}

                      background:

                      /* 🕛 SOLAR NOON (dominant) */
                      linear-gradient(
                        to bottom,
                        {{ top_color ~ 'FF' }} 0%,
                        {{ top_color ~ 'FF' }} 0%,
                        {{ top_color ~ 'FF' }} 0%,
                        {{ top_color ~ 'FF' }} 0%
