                align_header: center
                animate: false
                smoothing: true
                logarithmic: true
                line_width: 2
                font_size: 90
                hours_to_show: 8
                points_per_hour: 6
                height: 400
                show:
                  graph: bar
                  icon: false
                  labels: false
                  fill: true
                color_thresholds:
                  - value: 25
                    color: '#269d43'
                  - value: 45
                    color: '#e7b01d'
                  - value: 70
                    color: '#cc2b23'
                card_mod:
                  style: |
                    /* 1. DEFINE DYNAMIC COLOR & EMOJI */
                    {% set ping = states('sensor.starlink_ping') | float(0) %}
                    {% set active_color = '#269d43' %}
                    {% set status_emoji = '⚡⚡⚡' %}

                    {% if ping >= 70 %}
                      {% set active_color = '#cc2b23' %}
                      {% set status_emoji = '🔴🔴🔴' %}
                    {% elif ping >= 45 %}
                      {% set active_color = '#e7b01d' %}
                      {% set status_emoji = '🟡🟡🟡' %}
                    {% endif %}

                    /* 2. INJECT EMOJI INTO TITLE */
                    .header .name::before {
                      content: "{{ status_emoji }} ";
                    }

                    /* 3. POSITIONING & BACKGROUND */
                    ha-card {
                      position: relative;
                      background: linear-gradient(180deg, {{ active_color ~ '15' }} 0%, rgba(0,0,0,0) 100%) !important;
                    }

                    .header {
                      z-index: 2;
                      position: relative;
                    }

                    .states {
                      position: absolute;
                      top: 55%;
                      left: 50%;
                      transform: translate(-50%, -50%);
                      z-index: 2;
