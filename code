                      - value: 5
                        color: '#0F52BAAA'
                      - value: 6
                        color: '#00BCD44D'
                      - value: 7
                        color: '#9C27B04D'
                      - value: 8
                        color: '#F4511E4D'
                      - value: 9
                        color: '#1E88E54D'
                      - value: 10
                        color: '#1E88E54D'
                      - value: 11
                        color: '#FFC1074D'
                      - value: 12
                        color: '#E539354D'
                    card_mod:
                      style: >
                        :host {
                          --bubble-border-radius: 16px !important;
                        } /* 1. Transparent card background */  ha-card,
                        .bubble-card, .card-content, #card {
                          background: transparent !important;
                          box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.5) !important;
                          border-radius: 16px !important;          
                          padding: 0 !important;
                          position: relative;
                          top: -30px;
                          botttom: 0px;
                          z-index: -1;                        
                          width: 210px !important;    /* Set desired width */
                          max-width: 95% !important;   /* Or limit to % of parent */
                          margin-left: auto;             /* Center horizontally */
                          margin-right: auto;
                        } .header, .y-axis, .label, .value {
                          display: none !important;
                        } .content > * {
                          padding: 0 !important;
                          margin: 0 !important;
                          width: auto;
                          height: auto;
                        }
                    grid_options:
                      columns: 6
                      rows: null
              - type: vertical-stack
                cards:
                  - type: custom:bubble-card
                    card_type: button
                    button_type: state
                    show_state: true
                    show_last_changed: false
                    show_last_updated: false
                    grid_options:
                      columns: 4
                      rows: 1
                    name: Ayden Moto
                    icon: ''
                    show_attribute: false
                    force_icon: false
                    card_layout: normal
                    show_icon: false
                    scrolling_effect: false
                    entity: device_tracker.aydens_moto_g_stylus
                    sub_button:
                      main: []
                      bottom: []
                    card_mod:
                      style: >
