                {% elif lux >= 2500 %}{% set top_color = '#9FD6C8' %}

                {% elif lux >= 1000 %}{% set top_color = '#B8D9F2' %}

                {% elif lux >= 400 %}{% set top_color = '#78AEDD' %}

                {% elif lux >= 150 %}{% set top_color = '#4C7FB8' %}

                {% elif lux >= 60 %}{% set top_color = '#2A4C7A' %}

                {% elif lux >= 20 %}{% set top_color = '#1A2E5A' %}

                {% elif lux >= 5 %}{% set top_color = '#121A3A' %}

                {% elif lux >= 1 %}{% set top_color = '#0A1026' %}

                {% endif %}


                {% set is_night = is_state('sun.sun','below_horizon') %}

                {% set has_sun = not is_night %}

                {% set sun_state = states('sun.sun') %}

                {% set now_ts = as_timestamp(now()) %}

                {% set next_rise =
